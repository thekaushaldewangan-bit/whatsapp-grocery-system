# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/whatsapp-grocery

# Demo Mode (set to true to run without Twilio/OpenAI keys)
DEMO_MODE=true

# Twilio (required when DEMO_MODE=false)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# OpenAI - Whisper API (required when DEMO_MODE=false)
OPENAI_API_KEY=your_openai_api_key

# Payment (UPI)
UPI_ID=demo@upi
SHOP_NAME=Grocery Store
SHOP_PHONE=your_phone_number

# Admin
ADMIN_SECRET_KEY=your_super_secret_key_change_in_production
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# Frontend
REACT_APP_ADMIN_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
